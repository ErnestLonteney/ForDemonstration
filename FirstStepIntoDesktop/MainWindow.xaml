<Window x:Class="FiorstStepIntoDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FiorstStepIntoDesktop"
        mc:Ignorable="d"
        Title="Click Me application" Height="400" Width="700">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Vertical">
            <Label Grid.Column="0" Content="Input your age" HorizontalAlignment="Left" Margin="120,20,0,0" VerticalAlignment="Top" Width="125"/>
            <TextBox Grid.Column="0" Name="tbAgeInput" HorizontalAlignment="Left" Height="31" Margin="120,0,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="167" Background="#FFCAEDED"/>
            <RadioButton Name="rbStandard" Grid.Column="0" Content="Standard access" HorizontalAlignment="Left" Height="31" Margin="138,27,0,0" VerticalAlignment="Top" Width="166" IsChecked="True"/>
            <RadioButton Name="rbPremium" Grid.Column="0" Content="Premium access" HorizontalAlignment="Left" Height="25" Margin="138,0,0,0" VerticalAlignment="Top" Width="132"/>
            <CheckBox Grid.Column="0" Name="cbTerms" Content="I accept the terms and conditions" HorizontalAlignment="Left" Margin="121,50,0,0" VerticalAlignment="Top" Width="200"/>
            <Button Grid.Column="0" Content="Click Me!" Opacity="23" HorizontalAlignment="Left" Margin="102,10,0,0" VerticalAlignment="Top" Width="244" Height="61" Background="#FF56BFE2" FontWeight="Bold" FontSize="22" Foreground="#FF8834E0" Click="Button_Click"/>
        </StackPanel>
        <Image Grid.Column="1" Source="/avatar.jpg" HorizontalAlignment="Left" Margin="50,10,0,0" VerticalAlignment="Top" Width="250" Height="300"/>
    </Grid>
</Window>
